# URL del Google Apps Script Web App que captura leads del formulario de contacto.
# Cómo obtenerla: ver scripts/gas/README.md (pasos 1–4).
# Es NEXT_PUBLIC_ porque el formulario corre en el cliente; la URL es pública por
# diseño cuando el Web App se publica como "Anyone".
NEXT_PUBLIC_GAS_URL=https://script.google.com/macros/s/AKfycbxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx/exec
